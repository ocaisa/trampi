From 689a0869c8f58167e3b0b5db13f8ce8db5f24009 Mon Sep 17 00:00:00 2001
From: Hui Zhou <hzhou321@anl.gov>
Date: Mon, 20 Apr 2026 20:49:36 -0500
Subject: [PATCH] abi: cast to uintptr_t in ABI_IS_BUILTIN

On 32-bit systems, a pointer cast to intptr_t can be negative, which
makes the check for the range 0 to 0x1000 invalid. Cast to uintptr_t
fixes it.
---
 src/binding/abi/mpi_abi_util.h | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/binding/abi/mpi_abi_util.h b/src/binding/abi/mpi_abi_util.h
index 07be78989d8..ea598353bd4 100644
--- a/src/binding/abi/mpi_abi_util.h
+++ b/src/binding/abi/mpi_abi_util.h
@@ -4,7 +4,7 @@
 #include "mpi_abi_internal.h"
 #include "mpiimpl.h"
 
-#define ABI_IS_BUILTIN(h)  ((intptr_t)(h) < 0x1000)
+#define ABI_IS_BUILTIN(h)  ((uintptr_t)(h) < 0x1000)
 
 #define ABI_DATATYPE_BUILTIN_MASK 0x1ff
 #define ABI_OP_BUILTIN_MASK 0x1f
